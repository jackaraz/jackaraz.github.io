<aside class="header-overlap--overlapped | stack pad-horizontal pad-vertical">
  <section class="p-contact | stack lg:pad-top-800 priority-10">
    <h2>Contact</h2>
    {% include "./contactAddress.njk" %}
    {% include "./contactLinks.njk" %}
  </section>
  <section class="stack pad-top-600">
    <h2>Software</h2>
    <ul class="reset-list">
      <li class="p-skill"><a href="https://spey.readthedocs.io">Spey</a></li>
      <li class="p-skill"><a href="https://madanalysis.irmp.ucl.ac.be/">MadAnalysis 5</a></li>
      <li class="p-skill"><a href="https://elvet.gitlab.io/elvet/">Elvet</a></li>
      <li class="p-skill"><a href="https://heprivet.gitlab.io/">Rivet</a></li>
      <li class="p-skill"><a href="https://github.com/nabu-hep/nabu-hep">Nabu</a></li>
    </ul>
  </section>
  <section class="stack pad-top-600">
    <h2>Languages</h2>
    <ul class="reset-list">
    {% for language in general.languages %}
        <li class="p-skill">{{ language.name }}: {{ language.level }}</li>
    {% endfor %}
    {# theme-specific additions #}
    <li id="shire-language" class="p-skill theme-language">Dark Tongue of Mordor: Conversational</li>
    <li id="galaxy-language" class="p-skill theme-language">Wookiee: Professional Proficiency</li>
    </ul>
  </section>
  <section class="stack pad-top-600">
    <h2>Programming</h2>
    <ul class="reset-list">
    <li class="p-skill">{{ "Python, $$ \\texttt{C++}$$, $$ \\texttt{Fortran}$$, Julia" }}</li>
    <li class="p-skill">{{ "$$ \\texttt{bash\ script}$$, Mathematica" }}</li>
    </ul>
  </section>
  <section class="stack pad-top-600">
    <h2>High Performance Computing</h2>
    <ul class="reset-list">
    <li class="p-skill">{{ "GPU: CUDA NVIDIA" }}</li>
    <li class="p-skill">{{ "CPU: Linux (Debian, CentOS 7)" }}</li>
    </ul>
  </section>
</aside>
